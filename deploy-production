#!/usr/bin/env bash

set -Eeuo pipefail

current_branch="$(git branch --show-current)"
version_file="VERSION"
changelog_file="CHANGELOG.md"
version_bump="${VERSION_BUMP:-beta}"
release_baseline_ref="${RELEASE_BASELINE_REF:-origin/production}"

bump_version() {
    local version="$1"
    local mode="$2"
    local base prerelease major minor patch label number

    base="${version%%-*}"
    prerelease=""

    if [[ "$version" == *-* ]]; then
        prerelease="${version#*-}"
    fi

    IFS=. read -r major minor patch <<< "$base"

    if [[ ! "$major" =~ ^[0-9]+$ || ! "$minor" =~ ^[0-9]+$ || ! "$patch" =~ ^[0-9]+$ ]]; then
        echo "Version '$version' must look like 0.1.0 or 0.1.0-beta.1." >&2
        return 1
    fi

    case "$mode" in
        beta)
            if [[ "$prerelease" =~ ^([A-Za-z][A-Za-z0-9-]*)\.([0-9]+)$ ]]; then
                label="${BASH_REMATCH[1]}"
                number="${BASH_REMATCH[2]}"

                echo "${base}-${label}.$((number + 1))"
                return 0
            fi

            echo "${base}-beta.1"
            ;;
        patch)
            echo "${major}.${minor}.$((patch + 1))-beta.1"
            ;;
        minor)
            echo "${major}.$((minor + 1)).0-beta.1"
            ;;
        major)
            echo "$((major + 1)).0.0-beta.1"
            ;;
        none)
            echo "$version"
            ;;
        *)
            echo "VERSION_BUMP must be one of: beta, patch, minor, major, none." >&2
            return 1
            ;;
    esac
}

latest_release_subject() {
    local subject

    subject="$(git log --format=%s --no-merges -n 1 "$release_baseline_ref"..HEAD 2>/dev/null || true)"

    if [ -z "$subject" ]; then
        subject="$(git log --format=%s --no-merges -n 1 HEAD 2>/dev/null || true)"
    fi

    printf '%s\n' "$subject"
}

format_release_commit_lines() {
    local range="$release_baseline_ref..HEAD"

    if ! git rev-parse --verify "$release_baseline_ref" >/dev/null 2>&1; then
        range="HEAD"
    fi

    git log --reverse --no-merges --format='- `%h` %s' "$range"
}

update_changelog() {
    local version="$1"
    local current_version="$2"
    local today tmp commits

    today="$(date +%F)"
    tmp="$(mktemp)"
    commits="$(mktemp)"

    format_release_commit_lines > "$commits"

    if [ ! -s "$commits" ]; then
        printf -- '- Version-only deploy; no application commits found between production and main.\n' > "$commits"
    fi

    {
        printf '# Changelog\n\n'
        printf '## %s - %s\n\n' "$version" "$today"

        if [ "$version" != "$current_version" ]; then
            printf 'Version: `%s` -> `%s`\n\n' "$current_version" "$version"
        else
            printf 'Version: `%s`\n\n' "$version"
        fi

        printf 'Changes included:\n\n'
        cat "$commits"
        printf '\n'

        if [ -f "$changelog_file" ]; then
            sed '1{/^# Changelog$/d;}' "$changelog_file" | sed '1{/^$/d;}'
        fi
    } > "$tmp"

    mv "$tmp" "$changelog_file"
    rm -f "$commits"
}

if [ "$current_branch" != "main" ]; then
    echo "Deploy aborted: start from main, not '$current_branch'."
    exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Deploy aborted: working tree has uncommitted changes."
    git status --short
    exit 1
fi

if [ ! -f "$version_file" ]; then
    echo "Deploy aborted: $version_file is missing."
    exit 1
fi

echo "Fetching production baseline..."
git fetch origin production

current_version="$(tr -d '[:space:]' < "$version_file")"
next_version="$(bump_version "$current_version" "$version_bump")"
release_subject="$(latest_release_subject)"

echo "Updating changelog for $next_version"
update_changelog "$next_version" "$current_version"
git add "$changelog_file"

if [ "$next_version" != "$current_version" ]; then
    echo "Bumping app version: $current_version -> $next_version"
    printf '%s\n' "$next_version" > "$version_file"
    git add "$version_file"
fi

if ! git diff --cached --quiet; then
    if [ -n "$release_subject" ]; then
        git commit -m "Release v$next_version: $release_subject"
    else
        git commit -m "Release v$next_version"
    fi
else
    echo "No version or changelog changes to commit."
fi

echo "Pushing main..."
git push origin main

echo "Switching to production..."
git checkout production

echo "Fast-forwarding production from main..."
git merge --ff-only main

echo "Pushing production..."
git push origin production

echo "Switching back to main..."
git checkout main

echo "Production deploy triggered."
