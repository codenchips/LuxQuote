#!/usr/bin/env bash

set -Eeuo pipefail

current_branch="$(git branch --show-current)"
version_file="VERSION"
version_bump="${VERSION_BUMP:-beta}"

bump_version() {
    local version="$1"
    local mode="$2"
    local base prerelease major minor patch label number

    base="${version%%-*}"
    prerelease=""

    if [[ "$version" == *-* ]]; then
        prerelease="${version#*-}"
    fi

    IFS=. read -r major minor patch <<< "$base"

    if [[ ! "$major" =~ ^[0-9]+$ || ! "$minor" =~ ^[0-9]+$ || ! "$patch" =~ ^[0-9]+$ ]]; then
        echo "Version '$version' must look like 0.1.0 or 0.1.0-beta.1." >&2
        return 1
    fi

    case "$mode" in
        beta)
            if [[ "$prerelease" =~ ^([A-Za-z][A-Za-z0-9-]*)\.([0-9]+)$ ]]; then
                label="${BASH_REMATCH[1]}"
                number="${BASH_REMATCH[2]}"

                echo "${base}-${label}.$((number + 1))"
                return 0
            fi

            echo "${base}-beta.1"
            ;;
        patch)
            echo "${major}.${minor}.$((patch + 1))-beta.1"
            ;;
        minor)
            echo "${major}.$((minor + 1)).0-beta.1"
            ;;
        major)
            echo "$((major + 1)).0.0-beta.1"
            ;;
        none)
            echo "$version"
            ;;
        *)
            echo "VERSION_BUMP must be one of: beta, patch, minor, major, none." >&2
            return 1
            ;;
    esac
}

if [ "$current_branch" != "main" ]; then
    echo "Deploy aborted: start from main, not '$current_branch'."
    exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Deploy aborted: working tree has uncommitted changes."
    git status --short
    exit 1
fi

if [ ! -f "$version_file" ]; then
    echo "Deploy aborted: $version_file is missing."
    exit 1
fi

current_version="$(tr -d '[:space:]' < "$version_file")"
next_version="$(bump_version "$current_version" "$version_bump")"

if [ "$next_version" != "$current_version" ]; then
    echo "Bumping app version: $current_version -> $next_version"
    printf '%s\n' "$next_version" > "$version_file"
    git add "$version_file"
    git commit -m "Bump app version to $next_version"
else
    echo "App version unchanged: $current_version"
fi

echo "Pushing main..."
git push origin main

echo "Switching to production..."
git checkout production

echo "Fast-forwarding production from main..."
git merge --ff-only main

echo "Pushing production..."
git push origin production

echo "Switching back to main..."
git checkout main

echo "Production deploy triggered."
